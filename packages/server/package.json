{
	"name": "@zeocode/server",
	"type": "module",
	"private": true,
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"dev": "bun run --hot src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"postinstall": "bun run --cwd ../database db:generate"
	},
	"dependencies": {
		"@ai-sdk/google": "^3.0.79",
		"@ai-sdk/groq": "^3.0.39",
		"@hono/zod-validator": "^0.8.0",
		"@sentry/bun": "^10.53.1",
		"@sentry/hono": "^10.53.1",
		"@zeocode/database": "workspace:*",
		"@zeocode/shared": "workspace:*",
		"ai": "^6.0.191",
		"dotenv": "^17.4.2",
		"hono": "^4.12.22",
		"zod": "^4.4.3"
	}
}
