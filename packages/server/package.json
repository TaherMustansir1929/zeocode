    "@hono/zod-validator": "^0.7.6",
    "@polar-sh/sdk": "^0.47.1",
    "@zeocode/database": "workspace:*",
    "@zeocode/shared": "workspace:*",
    "ai": "^6.0.154",
    "dotenv": "^17.4.1",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
